{
  "mcpServers": {
    "computer_use": {
      "type": "stdio",
      "command": "<PATH_TO_VENV>/bin/python",
      "args": ["-m", "computer_use.mcp_server"],
      "cwd": "<PATH_TO_AGENT_FORGE>",
      "env": {
        "PYTHONPATH": "<PATH_TO_AGENT_FORGE>",
        "AGENT_FORGE_DEBUG": "1"
      }
    }
  }
}
