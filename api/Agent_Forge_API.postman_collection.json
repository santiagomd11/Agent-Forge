{
  "info": {
    "name": "Agent Forge API - Phase A",
    "description": "Phase A (Agents) API collection for the Agent Forge orchestration platform.\n\nCovers: Health, Agents (CRUD + run), Runs (lifecycle + control), Computer Use (status).\n\nRun order matters -- requests use collection variables set by earlier requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "agent_id",
      "value": ""
    },
    {
      "key": "run_id",
      "value": ""
    },
    {
      "key": "delete_agent_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Status is healthy', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('healthy');",
                  "});",
                  "",
                  "pm.test('Has module availability', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.modules).to.have.property('forge');",
                  "    pm.expect(json.modules).to.have.property('computer_use');",
                  "});",
                  "",
                  "pm.test('Has platform info', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.platform).to.be.a('string');",
                  "    pm.expect(json.version).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "Create Agent",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agents",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Research Topic\",\n  \"description\": \"Research a given topic using multiple sources. Produce a structured summary with key findings, supporting evidence, and a list of sources.\",\n  \"samples\": [\"## Example\\n\\n### Key Findings\\n1. Finding one...\"]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('agent_id', json.id);",
                  "",
                  "pm.test('Agent has id', function() {",
                  "    pm.expect(json.id).to.be.a('string');",
                  "    pm.expect(json.id).to.have.lengthOf.above(0);",
                  "});",
                  "",
                  "pm.test('Agent name matches', function() {",
                  "    pm.expect(json.name).to.eql('Research Topic');",
                  "});",
                  "",
                  "pm.test('Agent type is agent', function() {",
                  "    pm.expect(json.type).to.eql('agent');",
                  "});",
                  "",
                  "pm.test('Agent status is creating', function() {",
                  "    pm.expect(json.status).to.eql('creating');",
                  "});",
                  "",
                  "pm.test('Agent has forge_path field', function() {",
                  "    pm.expect(json).to.have.property('forge_path');",
                  "});",
                  "",
                  "pm.test('Agent has timestamps', function() {",
                  "    pm.expect(json.created_at).to.be.a('string');",
                  "    pm.expect(json.updated_at).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('Agent has schema arrays', function() {",
                  "    pm.expect(json.input_schema).to.be.an('array');",
                  "    pm.expect(json.output_schema).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Agent has samples', function() {",
                  "    pm.expect(json.samples).to.be.an('array');",
                  "    pm.expect(json.samples.length).to.eql(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Agent - Minimal",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agents",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summarize Text\",\n  \"description\": \"Summarize any given text into bullet points.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('Agent created with defaults', function() {",
                  "    pm.expect(json.type).to.eql('agent');",
                  "    pm.expect(json.status).to.eql('creating');",
                  "    pm.expect(json.provider).to.eql('anthropic');",
                  "    pm.expect(json.computer_use).to.eql(false);",
                  "    pm.expect(json.samples).to.be.an('array').that.is.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
