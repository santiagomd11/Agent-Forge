                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ name: 'Temp Agent for Deletion', description: 'Will be deleted immediately' }) }",
                  "}, function(err, res) {",
                  "    pm.collectionVariables.set('delete_agent_id', res.json().id);",
                  "});"
